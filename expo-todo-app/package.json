{
  "name": "expo-todo-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start:mock": "dotenv -e .env -e .env.mock -e .env.local -- expo start --ios",
    "start:local": "dotenv -e .env -e .env.dev -e .env.local -- expo start --clear",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "~/.maestro/bin/maestro test .maestro/flows",
    "test:e2e:smoke": "~/.maestro/bin/maestro test .maestro/flows --include-tags smoke",
    "android:local": "dotenv -e .env -e .env.dev -e .env.local -- expo start --android",
    "ios:local": "dotenv -e .env -e .env.dev -e .env.local -- expo start --ios",
    "web:local": "dotenv -e .env -e .env.dev -e .env.local -- expo start --web",
    "generate-api": "curl -s \"http://localhost:8080/q/openapi?format=json\" -o api-spec.json && openapi --input api-spec.json --output src/outcall/taskmanager/api/generated --client fetch",
    "generate-mocks": "node scripts/generate-mock-adapter.js",
    "generate": "npm run generate-api && npm run generate-mocks"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-localization": "~17.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.14",
    "react": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.0.0",
    "@types/react": "~19.1.10",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "msw-auto-mock": "^0.32.0",
    "openapi-typescript-codegen": "^0.30.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.ts",
      "src/domain/**/*.ts",
      "src/outcall/**/*.ts",
      "!src/outcall/**/api/generated/**"
    ]
  },
  "private": true
}
